# .env.example — copy to .env.local and fill in values

# Resend
RESEND_API_KEY=
RESEND_FROM_NOREPLY=noreply@deindex.me
RESEND_FROM_DELETE=delete@deindex.me

# HIBP
HIBP_API_KEY=

# JWT
JWT_SECRET=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=

# Upstash Redis (counter — the only persistent state)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://deindex.me
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Analytics (optional)
PLAUSIBLE_DOMAIN=deindex.me
